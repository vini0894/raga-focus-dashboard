# Template for Streamlit secrets.
# Copy this to `secrets.toml` (same folder) and fill in your values.
# NEVER commit secrets.toml to git — it's in .gitignore.

[app]
password = "change-me-before-deploying"

[oauth]
# Get these from your token.json + credentials.json
# Run the OAuth flow locally once, then copy values here for cloud deployment.
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
refresh_token = "your-refresh-token"
